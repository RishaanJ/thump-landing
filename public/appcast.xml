<?xml version="1.0" encoding="utf-8"?>
<!--
  Thump update feed (Sparkle appcast).

  Served at https://thump.rishaan.cc/appcast.xml — the SUFeedURL baked into the
  app. This starter feed has no <item> entries, which Sparkle reads as
  "you're up to date," so "Check for Updates…" works gracefully before the
  first release.

  To publish a release, DO NOT hand-edit this: run generate_appcast (see
  RELEASING.md in the Thump app repo), which regenerates this whole file with
  signed <item> entries, then copy the result here and re-deploy.
-->
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Thump</title>
    <link>https://thump.rishaan.cc/appcast.xml</link>
    <description>Most recent updates to Thump.</description>
    <language>en</language>
  </channel>
</rss>
